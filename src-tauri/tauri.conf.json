{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PortGUI",
  "version": "0.1.0",
  "identifier": "com.portgui.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PortGUI",
        "width": 520,
        "height": 700,
        "resizable": true,
        "minWidth": 400,
        "minHeight": 500,
        "decorations": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
